# CB Business Backend Environment Configuration
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control

# ============================================
# Application Configuration
# ============================================
APP_NAME=Cross-Border Business API
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://cb.3strategy.cc,http://admin.cb.3strategy.cc

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Connection string format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:changeme-postgres-password-123@139.224.42.111:5432/crawler_db

# ============================================
# Redis Configuration
# ============================================
# Connection string format: redis://:password@host:port
# NOTE: The password below needs verification - check infrastructure documentation
REDIS_URL=redis://:FWD4D75OKyQS7HOluA6J@139.224.42.111:6379
# Alternative if no password: redis://139.224.42.111:6379

# ============================================
# JWT Authentication
# ============================================
# Generate a strong secret key for production
# Use: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# WeChat Pay Configuration
# ============================================
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_merchant_id
WECHAT_API_KEY=your_wechat_api_key_v3
WECHAT_API_SERIAL=your_wechat_api_serial
WECHAT_CERT_PATH=/path/to/cert/apiclient_cert.pem
WECHAT_KEY_PATH=/path/to/cert/apiclient_key.pem
WECHAT_NOTIFY_URL=https://api.cb.3strategy.cc/api/v1/payments/wechat/notify

# ============================================
# Alipay Configuration (Backup payment method)
# ============================================
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://api.cb.3strategy.cc/api/v1/payments/alipay/notify

# ============================================
# MinIO Object Storage Configuration
# ============================================
MINIO_ENDPOINT=139.224.42.111:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=xhOSMeHNmxCgNTBpoQfH
MINIO_BUCKET_NAME=cb-business
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://s3.3strategy.cc:9000

# ============================================
# Email Configuration (Resend)
# ============================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@3strategy.cc
RESEND_FROM_NAME=Cross-Border Business
RESEND_REPLY_TO=support@3strategy.cc

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://cb.3strategy.cc,https://admin.cb.3strategy.cc

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# AI/OpenAI Configuration (for content generation)
# ============================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# ============================================
# Feature Flags
# ============================================
# Enable/disable features without code deployment
FEATURE_REGISTRATION_ENABLED=true
FEATURE_PAYMENT_WECHAT_ENABLED=false
FEATURE_PAYMENT_ALIPAY_ENABLED=false
FEATURE_AI_CONTENT_GENERATION_ENABLED=true

# ============================================
# Subscription Configuration
# ============================================
# Pricing (in CNY)
SUBSCRIPTION_PRO_MONTHLY_PRICE=99
SUBSCRIPTION_PRO_QUARTERLY_PRICE=269
SUBSCRIPTION_PRO_ANNUAL_PRICE=999
SUBSCRIPTION_ENTERPRISE_ANNUAL_PRICE=4999

# Usage limits
FREE_ARTICLE_VIEWS_PER_DAY=5
FREE_API_CALLS_PER_DAY=50
FREE_OPPORTUNITY_ACCESSES_PER_DAY=3

# ============================================
# Security Configuration
# ============================================
# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Session configuration
SESSION_COOKIE_NAME=cb_session
SESSION_COOKIE_SECURE=false  # Set to true in production with HTTPS
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE=86400  # 24 hours

# ============================================
# Worker/Background Jobs Configuration
# ============================================
# For Celery or similar task queue
CELERY_BROKER_URL=redis://:FWD4D75OKyQS7HOluA6J@139.224.42.111:6379/1
CELERY_RESULT_BACKEND=redis://:FWD4D75OKyQS7HOluA6J@139.224.42.111:6379/2

# ============================================
# Monitoring & Analytics
# ============================================
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development
GOOGLE_ANALYTICS_ID=your_ga_id
