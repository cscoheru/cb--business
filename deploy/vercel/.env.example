# Vercel Environment Variables Template
# Add these in Vercel Dashboard: Settings → Environment Variables

# ============================================
# Production Environment Variables
# ============================================

# API Endpoint (Production)
NEXT_PUBLIC_API_URL=https://api.cb.3strategy.cc

# Application (optional overrides)
NEXT_PUBLIC_APP_NAME=Cross-Border Business
NEXT_PUBLIC_APP_URL=https://cb.3strategy.cc

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=false

# ============================================
# Development/Preview Environment Variables
# ============================================

# For preview deployments, use staging API
# NEXT_PUBLIC_API_URL=https://staging-api.cb.3strategy.cc
