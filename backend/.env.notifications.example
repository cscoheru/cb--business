# 通知服务环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================================================
# Telegram Bot 通知 (推荐)
# ============================================================================

# 1. 创建Telegram Bot: 在Telegram中搜索 @BotFather，发送 /newbot
# 2. 获取Bot Token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# 3. 获取Chat ID: 搜索 @userinfobot，发送任意消息获取你的Chat ID
TELEGRAM_CHAT_ID=123456789

# ============================================================================
# 邮件通知 (可选)
# ============================================================================

# SMTP服务器配置 (Gmail示例)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password  # Gmail应用专用密码，不是账户密码
FROM_EMAIL=your-email@gmail.com
TO_EMAILS=recipient1@example.com,recipient2@example.com

# 其他SMTP服务示例:
# - QQ邮箱: smtp.qq.com:587
# - 163邮箱: smtp.163.com:465
# - SendGrid: smtp.sendgrid.net:587

# ============================================================================
# WhatsApp通知 (Twilio)
# ============================================================================

# 1. 注册Twilio账号: https://www.twilio.com/
# 2. 启用WhatsApp Sandbox
# 3. 获取Account SID和Auth Token
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token

# Twilio Sandbox号码 (固定)
WHATSAPP_FROM_NUMBER=+14155238886

# 你的手机号 (需要先加入Sandbox: 发送 join<keyword> 到给定号码)
WHATSAPP_TO_NUMBER=+861xxxxxxxxxx

# ============================================================================
# 通知行为配置
# ============================================================================

# 是否在健康状态时发送通知 (每日摘要)
NOTIFY_ON_HEALTHY=true

# 是否在警告状态时发送通知
NOTIFY_ON_WARNING=true

# 是否在严重状态时发送通知
NOTIFY_ON_CRITICAL=true

# 通知发送时间范围 (小时，0-23)
# 只在此时段内发送通知
NOTIFICATION_START_HOUR=6
NOTIFICATION_END_HOUR=23
