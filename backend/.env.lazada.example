# ==========================================
# Lazada Open Platform API 配置
# ==========================================
# 注册地址: https://open.lazada.com/
# 文档: https://open.lazada.com/apps/doc/api

# Lazada 应用凭证 (从 https://open.lazada.com/ 获取)
LAZADA_APP_KEY=your_app_key_here
LAZADA_APP_SECRET=your_app_secret_here

# OAuth 回调地址 (需要与 Lazada 应用配置一致)
LAZADA_REDIRECT_URI=https://www.zenconsult.top/api/v1/lazada/callback

# 访问令牌 (通过 OAuth 授权后获取，或手动配置)
LAZADA_ACCESS_TOKEN=your_access_token_here
LAZADA_REFRESH_TOKEN=your_refresh_token_here

# 支持的国家 (th=泰国, vn=越南, my=马来西亚, sg=新加坡, id=印尼, ph=菲律宾)
LAZADA_DEFAULT_COUNTRY=th

# ==========================================
# 获取凭证步骤：
# ==========================================
# 1. 访问 https://open.lazada.com/ 注册开发者账号
# 2. 创建应用获取 App Key 和 App Secret
# 3. 配置应用的重定向 URI (Redirect URI)
# 4. 运行 OAuth 授权流程获取 Access Token
#    或者手动填写已有凭证
