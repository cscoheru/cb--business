# Railway Environment Variables Template
# Add these in Railway Dashboard: Variables tab

# ============================================
# Database Configuration
# ============================================
# Note: Railway can provide a managed PostgreSQL database
# Uncomment and use Railway's database if preferred

# DATABASE_URL=${{Postgres.DATABASE_URL}}
# Or use external database:
DATABASE_URL=postgresql://postgres:changeme-postgres-password-123@139.224.42.111:5432/crawler_db

# ============================================
# Redis Configuration
# ============================================
# Note: Railway can provide a managed Redis instance
# Uncomment and use Railway's Redis if preferred

# REDIS_URL=${{Redis.REDIS_URL}}
# Or use external Redis:
REDIS_URL=redis://:FWD4D75OKyQS7HOluA6J@139.224.42.111:6379

# ============================================
# Application Configuration
# ============================================
APP_NAME=Cross-Border Business API
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=https://www.zenconsult.top,https://admin.zenconsult.top
PORT=8000

# ============================================
# JWT Authentication
# ============================================
# Generate strong secret for production!
SECRET_KEY=${{secrets.PRODUCTION_SECRET_KEY}}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# WeChat Pay Configuration
# ============================================
WECHAT_APP_ID=${{secrets.WECHAT_APP_ID}}
WECHAT_MCH_ID=${{secrets.WECHAT_MCH_ID}}
WECHAT_API_KEY=${{secrets.WECHAT_API_KEY}}
WECHAT_NOTIFY_URL=https://api.zenconsult.top/api/v1/payments/wechat/notify

# ============================================
# MinIO Object Storage
# ============================================
MINIO_ENDPOINT=139.224.42.111:9000
MINIO_ACCESS_KEY=${{secrets.MINIO_ACCESS_KEY}}
MINIO_SECRET_KEY=${{secrets.MINIO_SECRET_KEY}}
MINIO_BUCKET_NAME=cb-business
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://s3.zenconsult.top

# ============================================
# Email Configuration (Resend)
# ============================================
RESEND_API_KEY=${{secrets.RESEND_API_KEY}}
RESEND_FROM_EMAIL=noreply@zenconsult.top
RESEND_FROM_NAME=Cross-Border Business

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=https://www.zenconsult.top,https://admin.zenconsult.top

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Feature Flags
# ============================================
FEATURE_REGISTRATION_ENABLED=true
FEATURE_PAYMENT_WECHAT_ENABLED=false
FEATURE_AI_CONTENT_GENERATION_ENABLED=true

# ============================================
# Subscription Pricing
# ============================================
SUBSCRIPTION_PRO_MONTHLY_PRICE=99
SUBSCRIPTION_PRO_QUARTERLY_PRICE=269
SUBSCRIPTION_PRO_ANNUAL_PRICE=999
SUBSCRIPTION_ENTERPRISE_ANNUAL_PRICE=4999

# ============================================
# Usage Limits
# ============================================
FREE_ARTICLE_VIEWS_PER_DAY=5
FREE_API_CALLS_PER_DAY=50
FREE_OPPORTUNITY_ACCESSES_PER_DAY=3

# ============================================
# Security Configuration
# ============================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Session configuration
SESSION_COOKIE_NAME=cb_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE=86400

# ============================================
# Background Jobs (Celery)
# ============================================
CELERY_BROKER_URL=${{Redis.REDIS_URL}}
CELERY_RESULT_BACKEND=${{Redis.REDIS_URL}}

# ============================================
# Monitoring
# ============================================
SENTRY_DSN=${{secrets.SENTRY_DSN}}
SENTRY_ENVIRONMENT=production
